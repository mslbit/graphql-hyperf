{
    "name": "maiscraft/graphql-hyperf",
    "description": "Hyperf adapter for Maiscraft GraphQL - Auto-wiring, PSR container bridge, HTTP controller, and configuration provider",
    "type": "library",
    "license": "MIT",

    "authors": [
        {
            "name": "MaisCraft Team",
            "email": "team@mslbit.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "hyperf/framework": "^3.1",
        "hyperf/di": "^3.1",
        "hyperf/cache": "^3.1",
        "hyperf/event": "^3.1",
        "hyperf/http-server": "^3.1",
        "hyperf/command": "^3.1",
        "maiscraft/graphql": "dev-main",
        "maiscraft/rbac": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Maiscraft\\GraphQLHyperf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maiscraft\\GraphQLHyperf\\Tests\\": "tests/"
        }
    },
    "extra": {
        "hyperf": {
            "config": "Maiscraft\\GraphQLHyperf\\ConfigProvider"
        }
    },
    "keywords": [
        "graphql",
        "hyperf",
        "php8",
        "swoole",
        "adapter",
        "psr-11"
    ],
    "homepage": "https://github.com/mslbit/graphql-hyperf",
    "support": {
        "issues": "https://github.com/mslbit/graphql-hyperf/issues",
        "source": "https://github.com/mslbit/graphql-hyperf"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
